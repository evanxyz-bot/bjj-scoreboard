{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BJJ.Score",
  "version": "1.0.0",
  "identifier": "com.bjjscore.scoreboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "BJJ.Score",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/evanxyz-bot/bjj-scoreboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0MzIyRjUxMUZGNEQwMDkKUldRSjBQUWZVUzh5VkVtd3ZpSEo3MHl5UVo5K0ZoVmxQeUVUNnorZnk0ZytNZ2lpc3RvWmlBcTgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
